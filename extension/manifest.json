{
  "manifest_version": 3,
  "name": "AgentOS Bridge",
  "version": "3.0.0",
  "description": "Turn any AI chat into an autonomous agent with browser control. Navigate, click, type, scrape — the AI agent for everyone.",
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "tabs",
    "scripting"
  ],
  "oauth2": {
    "client_id": "930312309217-9tgvu1i7o3hrogrmnooplbpgminq54m9.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "host_permissions": [
    "https://docs.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://sheets.googleapis.com/*",
    "https://accounts.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AgentOS Bridge"
  }
}
