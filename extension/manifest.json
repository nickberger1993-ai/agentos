{
  "manifest_version": 3,
  "name": "AgentOS",
  "version": "4.3.0",
  "description": "Turn any AI into a persistent autonomous agent. Free. No server. Just Google.",
  "permissions": [
    "identity",
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://docs.googleapis.com/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://gmail.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AgentOS"
  }
}
